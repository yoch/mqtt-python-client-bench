# Generated TLS material (ensure_certs regenerates everything; committing the
# .crt without its gitignored .key desyncs fresh checkouts)
certs/

# Local run artefacts (committed results/*.json are publication outputs only)
calibrations/
logs/
results/_*.json
results/*-smoke.json
results/*.log
site/
!results/.gitkeep

# Ephemeral NanoMQ / broker probe configs
.nanomq-probe/

# Local tooling
.venv/
.venv-*/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
dist/
build/
